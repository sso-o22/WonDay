@inherits LayoutComponentBase
@inject SupabaseService Supabase
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (!_checked)
{
    <div class="app-shell">
        <div class="empty-state" style="padding-top: 40vh;">불러오는 중...</div>
    </div>
}
else if (_callbackError is not null)
{
    <div class="app-shell">
        <div class="empty-state" style="padding-top: 20vh; text-align: left; padding-left: 16px; padding-right: 16px;">
            <div style="text-align: center; margin-bottom: 16px;">로그인 처리 중 문제가 발생했어요.</div>
            <div style="background: var(--color-surface-alt); border-radius: 10px; padding: 12px; font-size: 11px; font-family: monospace; white-space: pre-wrap; word-break: break-all; color: var(--color-text-secondary);">@_callbackError</div>
            <div style="text-align: center; margin-top: 16px;">
                <a href="/login" class="btn btn-primary" style="display: inline-block; text-decoration: none;">로그인 다시 시도</a>
            </div>
        </div>
    </div>
}
else if (!Supabase.IsLoggedIn && !IsLoginPage)
{
    <div class="app-shell">
        <div class="empty-state" style="padding-top: 40vh;">
            로그인이 필요해요.<br />
            <a href="/login" class="btn btn-primary" style="display: inline-block; margin-top: 12px; text-decoration: none;">로그인 화면으로 이동</a>
        </div>
    </div>
}
else
{
    <div class="app-shell">
        <main class="app-main">
            @Body
        </main>
        @if (!IsLoginPage)
        {
            <NavMenu />
        }
    </div>
}

@code {
    bool _checked;
    string? _callbackError;

    bool IsLoginPage => Nav.Uri.Contains("/login");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 구글 로그인 후 돌아왔다면 URL 조각(#access_token=...&refresh_token=...)에 토큰이 실려와요.
            var accessToken = GetUriPart(Nav.Uri, "access_token", isFragment: true);
            var refreshToken = GetUriPart(Nav.Uri, "refresh_token", isFragment: true);

            // 실패한 경우 에러가 쿼리 또는 조각 어디에 실려올지 몰라서 둘 다 확인합니다.
            var oauthError = GetUriPart(Nav.Uri, "error_description", isFragment: false)
                ?? GetUriPart(Nav.Uri, "error_description", isFragment: true)
                ?? GetUriPart(Nav.Uri, "error", isFragment: false)
                ?? GetUriPart(Nav.Uri, "error", isFragment: true);

            if (!string.IsNullOrEmpty(oauthError))
            {
                _callbackError = $"OAuth 오류: {oauthError}";
                _checked = true;
                return;
            }

            if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(refreshToken))
            {
                try
                {
                    await Supabase.SetSessionAsync(accessToken, refreshToken);
                }
                catch (Exception setSessionEx)
                {
                    _callbackError = $"세션 설정 실패: {setSessionEx.GetType().Name} - {setSessionEx.Message}";
                    _checked = true;
                    return;
                }

                // 주소창에 남은 #access_token=... 를 지우고 깔끔한 홈 주소로 정리합니다.
                Nav.NavigateTo("/", forceLoad: false, replace: true);
            }

            _checked = true;
        }
        catch (Exception ex)
        {
            _callbackError = $"예상치 못한 오류: {ex.GetType().Name} - {ex.Message}";
            _checked = true;
        }
    }

    // isFragment: true면 '#' 뒤쪽에서, false면 '?' 뒤쪽(쿼리스트링)에서 값을 찾습니다.
    static string? GetUriPart(string uri, string key, bool isFragment)
    {
        var marker = isFragment ? '#' : '?';
        var start = uri.IndexOf(marker);
        if (start < 0) return null;

        var part = uri[(start + 1)..];

        // 쿼리 파싱 시 조각(#) 이후는 잘라내고, 조각 파싱 시 그 뒤에 또 ?가 있으면 그대로 둡니다.
        if (!isFragment)
        {
            var fragmentIndex = part.IndexOf('#');
            if (fragmentIndex >= 0) part = part[..fragmentIndex];
        }

        foreach (var pair in part.Split('&'))
        {
            var kv = pair.Split('=', 2);
            if (kv.Length == 2 && Uri.UnescapeDataString(kv[0]) == key)
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }
}
