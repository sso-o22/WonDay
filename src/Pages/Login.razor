@page "/login"
@inject SupabaseService Supabase
@inject NavigationManager Nav
@inject IJSRuntime JS

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; padding: 24px; text-align: center;">
    <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--color-accent-bg); display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
        <i class="ti ti-pig-money" style="font-size: 30px; color: var(--color-accent-strong);" aria-hidden="true"></i>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 4px;">원데이</h1>
    <p style="color: var(--color-text-secondary); margin-bottom: 40px;">매일 쓰는 우리집 가계부</p>

    <button class="btn btn-primary btn-full" style="max-width: 280px; display: flex; align-items: center; justify-content: center; gap: 8px;" @onclick="SignIn">
        <i class="ti ti-brand-google" aria-hidden="true"></i>
        Google로 계속하기
    </button>

    <p style="font-size: 13px; color: var(--color-text-muted); margin-top: 16px; max-width: 260px;">
        구글 로그인 한 번이면 기록이 클라우드에 안전하게 보관되고, 배우자와도 바로 공유할 수 있어요.
    </p>

    @if (_error is not null)
    {
        <p class="text-danger" style="margin-top: 16px; font-size: 14px;">@_error</p>
    }
</div>

@code {
    string? _error;

    async Task SignIn()
    {
        try
        {
            // 로그인 후 돌아올 주소는 이 로그인 페이지가 아니라 앱 홈으로 지정합니다.
            var redirectUrl = Nav.BaseUri;
            var state = await Supabase.GetGoogleSignInStateAsync(redirectUrl);

            // Implicit 플로우라 별도로 저장해둘 값이 없어요 - 바로 구글 로그인 화면으로 이동합니다.
            await JS.InvokeVoidAsync("window.location.assign", state.Uri!.ToString());
        }
        catch (Exception ex)
        {
            _error = $"로그인 시작 실패: {ex.GetType().Name} - {ex.Message}";
            Console.Error.WriteLine(ex);
        }
    }
}
