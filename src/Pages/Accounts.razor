    }

    void OpenCopyPrompt(string ciphertext, string iv, string salt)
    {
        _revealTarget = new EncryptedValue { Ciphertext = ciphertext, Iv = iv, Salt = salt };
        RequestPin(pin => _ = RevealAndCopy(pin));
    }

    async Task RevealAndCopy(string pin)
    {
        if (_revealTarget is null) return;

        try
        {
            var plaintext = await Crypto.DecryptAsync(_revealTarget, pin);
            await Crypto.CopyToClipboardAsync(plaintext);
            _copiedMessage = "클립보드에 복사됐어요";
            StateHasChanged();
            await Task.Delay(2000);
            _copiedMessage = null;
            StateHasChanged();
        }
        catch
        {
            _pinPromptMode = PinMode.Reveal;
            _pinError = "PIN이 틀렸어요. 다시 시도해주세요.";
            _pinConfirmedCallback = pin2 => _ = RevealAndCopy(pin2);
            StateHasChanged();
        }
    }

    // 이 세션에서 PIN을 이미 입력한 적 있으면 (계좌번호 저장을 이미 한 번이라도 했으면) 그 창은 생략하고,
    // 없으면 새 PIN 만들기/입력 창을 띄웁니다.
    void RequestPin(Action<string> onConfirmed)
    {
        _pinConfirmedCallback = onConfirmed;
        _pinInput = "";
        _pinError = null;
        _pinPromptMode = Crypto.HasPinForSession ? PinMode.Reveal : PinMode.SetNew;
    }

    void ConfirmPin()
    {
        if (string.IsNullOrWhiteSpace(_pinInput))
        {
            _pinError = "PIN을 입력해주세요.";
            return;
        }

        var pin = _pinInput;
        var callback = _pinConfirmedCallback;
        _pinPromptMode = null;
        _pinInput = "";
        callback?.Invoke(pin);
    }

    void ClosePinPrompt()
    {
        _pinPromptMode = null;
        _pinInput = "";
        _pinError = null;
        _pinConfirmedCallback = null;
    }

