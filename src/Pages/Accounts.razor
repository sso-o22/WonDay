@page "/accounts"
@inject AccountRepository AccountRepo
@inject CardRepository CardRepo
@inject TransactionRepository TransactionRepo
@inject HouseholdRepository HouseholdRepo

<h1 style="font-size: 18px; margin: 0 0 16px;">계좌 · 카드</h1>

<h2 style="font-size: 14px; margin: 0 0 10px;">계좌</h2>

@if (_accounts.Count == 0)
{
    <div class="empty-state">등록된 계좌가 없어요.</div>
}
else
{
    @foreach (var a in _accounts)
    {
        <div class="card" style="display: flex; align-items: center; justify-content: space-between;">
            <div>
                <div style="font-size: 13px; font-weight: 600;">@a.Name</div>
                <div style="font-size: 11px; color: var(--color-text-muted);">@(a.IsShared ? "같이 보기" : "나만 보기") · @(a.Type == "cash" ? "현금" : "계좌")</div>
            </div>
            <div style="font-size: 14px; font-weight: 600;">@AccountRepo.CalculateBalance(a, _allTransactions).ToString("N0")원</div>
        </div>
    }
}

<button class="btn btn-full" style="margin-bottom: 20px;" @onclick="() => _showAddAccount = true">+ 계좌 추가</button>

<h2 style="font-size: 14px; margin: 0 0 10px;">카드</h2>

@if (_cards.Count == 0)
{
    <div class="empty-state">등록된 카드가 없어요.</div>
}
else
{
    @foreach (var c in _cards)
    {
        <div class="card" style="display: flex; align-items: center; justify-content: space-between;">
            <div>
                <div style="font-size: 13px; font-weight: 600;">@c.Name</div>
                <div style="font-size: 11px; color: var(--color-text-muted);">매월 @(c.StatementDay)일 마감 · @(c.PaymentDay)일 결제</div>
            </div>
            <div style="font-size: 14px; font-weight: 600;">@CardRepo.CalculateCurrentStatementAmount(c, _allTransactions, DateTime.Today).ToString("N0")원</div>
        </div>
    }
}

<button class="btn btn-full" style="margin-bottom: 20px;" @onclick="() => _showAddCard = true">+ 카드 추가</button>

<h2 style="font-size: 14px; margin: 0 0 10px;">배우자 초대</h2>

<div class="card">
    <div class="form-group">
        <label class="form-label">배우자 이메일</label>
        <input class="form-input" @bind="_inviteEmail" placeholder="name@example.com" />
    </div>
    <button class="btn btn-primary btn-full" @onclick="SendInvite">초대 보내기</button>
    @if (_inviteMessage is not null)
    {
        <p style="font-size: 12px; color: var(--color-text-secondary); margin-top: 8px;">@_inviteMessage</p>
    }
</div>

@if (_showAddAccount)
{
    <div class="modal-backdrop" @onclick="() => _showAddAccount = false">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 16px; margin: 0 0 16px;">계좌 추가</h2>
            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_newAccountName" placeholder="예: 생활비 통장" />
            </div>
            <div class="form-group">
                <label class="form-label">시작 잔액</label>
                <input class="form-input" type="number" @bind="_newAccountBalance" placeholder="0" />
            </div>
            <div class="toggle-group" style="margin-bottom: 16px;">
                <button class="@(_newAccountShared ? "" : "active")" @onclick="() => _newAccountShared = false">나만 보기</button>
                <button class="@(_newAccountShared ? "active" : "")" @onclick="() => _newAccountShared = true">같이 보기</button>
            </div>
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="() => _showAddAccount = false">취소</button>
                <button class="btn btn-primary" style="flex: 2;" @onclick="AddAccount">추가</button>
            </div>
        </div>
    </div>
}

@if (_showAddCard)
{
    <div class="modal-backdrop" @onclick="() => _showAddCard = false">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 16px; margin: 0 0 16px;">카드 추가</h2>
            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_newCardName" placeholder="예: 신한카드" />
            </div>
            <div class="form-group">
                <label class="form-label">청구 마감일 (일)</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_newCardStatementDay" />
            </div>
            <div class="form-group">
                <label class="form-label">결제일 (일)</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_newCardPaymentDay" />
            </div>
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="() => _showAddCard = false">취소</button>
                <button class="btn btn-primary" style="flex: 2;" @onclick="AddCard">추가</button>
            </div>
        </div>
    </div>
}

@code {
    List<Account> _accounts = new();
    List<Card> _cards = new();
    List<Transaction> _allTransactions = new();

    bool _showAddAccount;
    string _newAccountName = "";
    decimal _newAccountBalance;
    bool _newAccountShared;

    bool _showAddCard;
    string _newCardName = "";
    int _newCardStatementDay = 15;
    int _newCardPaymentDay = 25;

    string _inviteEmail = "";
    string? _inviteMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    async Task LoadAll()
    {
        _accounts = await AccountRepo.GetAllAsync();
        _cards = await CardRepo.GetAllAsync();

        // 잔액/청구액 계산을 위해 최근 12개월치 거래를 모아옵니다.
        var all = new List<Transaction>();
        var today = DateTime.Today;
        for (var i = 0; i < 12; i++)
        {
            var month = today.AddMonths(-i);
            all.AddRange(await TransactionRepo.GetByMonthAsync(month.Year, month.Month));
        }
        _allTransactions = all;
    }

    async Task AddAccount()
    {
        if (string.IsNullOrWhiteSpace(_newAccountName)) return;

        await AccountRepo.CreateAsync(new Account
            {
                Name = _newAccountName,
                Type = "bank",
                InitialBalance = _newAccountBalance
            }, _newAccountShared);

        _newAccountName = "";
        _newAccountBalance = 0;
        _showAddAccount = false;
        await LoadAll();
    }

    async Task AddCard()
    {
        if (string.IsNullOrWhiteSpace(_newCardName)) return;

        await CardRepo.CreateAsync(new Card
            {
                Name = _newCardName,
                StatementDay = _newCardStatementDay,
                PaymentDay = _newCardPaymentDay
            }, isShared: false);

        _newCardName = "";
        _showAddCard = false;
        await LoadAll();
    }

    async Task SendInvite()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail)) return;

        await HouseholdRepo.InviteAsync(_inviteEmail);
        _inviteMessage = $"{_inviteEmail}로 초대를 보냈어요.";
        _inviteEmail = "";
    }
}
