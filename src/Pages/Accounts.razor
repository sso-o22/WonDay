    Task SaveInstallment() => _editingInstallment is null ? AddInstallment() : UpdateInstallment();

    async Task UpdateInstallment()
    {
        if (_editingInstallment is null || _isSaving) return;

        if (string.IsNullOrEmpty(_newInstallmentCardId) || string.IsNullOrWhiteSpace(_newInstallmentMerchant)
            || _newInstallmentTotal <= 0 || _newInstallmentMonths <= 0 || _newInstallmentMonths < _editingInstallment.MonthsGenerated)
        {
            _error = _newInstallmentMonths < _editingInstallment.MonthsGenerated
                ? "이미 기록된 회차보다 적은 개월수로는 바꿀 수 없어요."
                : "필수 항목을 모두 입력해주세요.";
            return;
        }

        _isSaving = true;
        try
        {
            _editingInstallment.CardId = Guid.Parse(_newInstallmentCardId);
            _editingInstallment.CategoryId = string.IsNullOrEmpty(_newInstallmentCategoryId) ? null : Guid.Parse(_newInstallmentCategoryId);
            _editingInstallment.Merchant = _newInstallmentMerchant;
            _editingInstallment.TotalAmount = _newInstallmentTotal;
            _editingInstallment.MonthsCount = _newInstallmentMonths;
            await InstallmentRepo.UpdateAsync(_editingInstallment);
        }
        catch (Exception ex)
        {
            _error = $"저장 실패: {ex.Message}";
            return;
        }
        finally
        {
            _isSaving = false;
        }

        CloseAddInstallment();
        await LoadAll();
    }

    async Task AddInstallment()
    {
        if (_isSaving) return;

        if (string.IsNullOrEmpty(_newInstallmentCardId) || string.IsNullOrWhiteSpace(_newInstallmentMerchant)
            || _newInstallmentTotal <= 0 || _newInstallmentMonths <= 0)
        {
            _error = "필수 항목을 모두 입력해주세요.";
            return;
        }

        _isSaving = true;
        try
        {
            var startDate = DateTime.ParseExact(_newInstallmentStartMonth + "-01", "yyyy-MM-dd", null);
            Guid? categoryId = string.IsNullOrEmpty(_newInstallmentCategoryId) ? null : Guid.Parse(_newInstallmentCategoryId);

            await InstallmentRepo.CreateAsync(
                Guid.Parse(_newInstallmentCardId), categoryId, _newInstallmentMerchant,
                _newInstallmentTotal, _newInstallmentMonths, startDate, isShared: false);

            // 첫 청구월이 이미 지났으면(예: 이번 달로 설정) 바로 거래로 반영합니다.
            await InstallmentRepo.GenerateDueTransactionsAsync();
        }
        catch (Exception ex)
        {
            _error = $"저장 실패: {ex.Message}";
            return;
        }
        finally
        {
            _isSaving = false;
        }

        CloseAddInstallment();
        await LoadAll();
    }

