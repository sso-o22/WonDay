@page "/accounts"
@inject AccountRepository AccountRepo
@inject CardRepository CardRepo
@inject TransactionRepository TransactionRepo
@inject HouseholdRepository HouseholdRepo
@inject AccountNumberCryptoService Crypto
@inject InstallmentPlanRepository InstallmentRepo
@inject CategoryRepository CategoryRepo

<h1 style="font-size: 19px; margin: 0 0 16px;">계좌 · 카드</h1>

<h2 style="font-size: 15px; margin: 0 0 10px;">계좌</h2>

@if (_accounts.Count == 0)
{
    <div class="empty-state">등록된 계좌가 없어요.</div>
}
else
{
    @foreach (var a in _accounts)
    {
        <div class="card">
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <div style="font-size: 14px; font-weight: 600;">@a.Name</div>
                    <div style="font-size: 12px; color: var(--color-text-muted);">@(a.IsShared ? "같이 보기" : "나만 보기") · @(a.Type == "cash" ? "현금" : "계좌")</div>
                </div>
                <div style="text-align: right;">
                    <div style="font-size: 15px; font-weight: 600;">@AccountRepo.CalculateBalance(a, _allTransactions).ToString("N0")원</div>
                    <div style="display: flex; gap: 6px; margin-top: 6px;">
                        <button class="btn" style="padding: 4px 8px; font-size: 12px;" @onclick="() => OpenEditAccount(a)">수정</button>
                        <button class="btn" style="padding: 4px 8px; font-size: 12px;" @onclick="() => DeleteAccount(a.Id)">삭제</button>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(a.EncryptedNumber))
            {
                <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--color-border); display: flex; align-items: center; justify-content: space-between;">
                    <span style="font-size: 12px; color: var(--color-text-muted); letter-spacing: 1px;">•••• 암호화된 계좌번호</span>
                    <button class="btn" style="padding: 5px 10px; font-size: 12px;" @onclick="() => OpenCopyPrompt(a.EncryptedNumber!, a.EncryptionIv!, a.EncryptionSalt!)">복사</button>
                </div>
            }
        </div>
    }
}

<button class="btn btn-full" style="margin-bottom: 20px;" @onclick="() => _showAddAccount = true">+ 계좌 추가</button>

<h2 style="font-size: 15px; margin: 0 0 10px;">카드</h2>

@if (_cards.Count == 0)
{
    <div class="empty-state">등록된 카드가 없어요.</div>
}
else
{
    @foreach (var c in _cards)
    {
        <div class="card">
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <div style="font-size: 14px; font-weight: 600;">@c.Name</div>
                    <div style="font-size: 12px; color: var(--color-text-muted);">매월 @(c.StatementDay)일 마감 · @(c.PaymentDay)일 결제</div>
                </div>
                <div style="text-align: right;">
                    <div style="font-size: 15px; font-weight: 600;">@CardRepo.CalculateCurrentStatementAmount(c, _allTransactions, DateTime.Today).ToString("N0")원</div>
                    <div style="display: flex; gap: 6px; margin-top: 6px;">
                        <button class="btn" style="padding: 4px 8px; font-size: 12px;" @onclick="() => OpenEditCard(c)">수정</button>
                        <button class="btn" style="padding: 4px 8px; font-size: 12px;" @onclick="() => DeleteCard(c.Id)">삭제</button>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(c.EncryptedNumber))
            {
                <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--color-border); display: flex; align-items: center; justify-content: space-between;">
                    <span style="font-size: 12px; color: var(--color-text-muted); letter-spacing: 1px;">•••• 암호화된 카드번호</span>
                    <button class="btn" style="padding: 5px 10px; font-size: 12px;" @onclick="() => OpenCopyPrompt(c.EncryptedNumber!, c.EncryptionIv!, c.EncryptionSalt!)">복사</button>
                </div>
            }
        </div>
    }
}

<button class="btn btn-full" style="margin-bottom: 20px;" @onclick="() => _showAddCard = true">+ 카드 추가</button>

<h2 style="font-size: 15px; margin: 0 0 10px;">할부</h2>

@if (_installments.Count == 0)
{
    <div class="empty-state">등록된 할부가 없어요.</div>
}
else
{
    @foreach (var p in _installments)
    {
        var cardName = _cards.FirstOrDefault(c => c.Id == p.CardId)?.Name ?? "카드";
        var progress = p.MonthsCount > 0 ? (double)p.MonthsGenerated / p.MonthsCount * 100 : 0;
        <div class="card">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
                <div>
                    <div style="font-size: 14px; font-weight: 600;">@p.Merchant</div>
                    <div style="font-size: 12px; color: var(--color-text-muted);">@cardName · 월 @p.MonthlyAmount.ToString("N0")원</div>
                </div>
                <div style="display: flex; gap: 6px;">
                    <button class="btn" style="padding: 5px 10px; font-size: 12px;" @onclick="() => OpenEditInstallment(p)">수정</button>
                    <button class="btn" style="padding: 5px 10px; font-size: 12px;" @onclick="() => DeleteInstallment(p.Id)">삭제</button>
                </div>
            </div>
            <div class="progress-track">
                <div class="progress-fill" style="width: @(progress.ToString("0"))%;"></div>
            </div>
            <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 4px;">
                @p.MonthsGenerated / @p.MonthsCount 개월 진행 · 총 @p.TotalAmount.ToString("N0")원
            </div>
        </div>
    }
}

<button class="btn btn-full" style="margin-bottom: 20px;" @onclick="OpenAddInstallment">+ 할부 추가</button>

<h2 style="font-size: 15px; margin: 0 0 10px;">배우자 초대</h2>

<div class="card">
    <div class="form-group">
        <label class="form-label">배우자 이메일</label>
        <input class="form-input" @bind="_inviteEmail" placeholder="name@example.com" />
    </div>
    <button class="btn btn-primary btn-full" @onclick="SendInvite">초대 보내기</button>
    @if (_inviteMessage is not null)
    {
        <p style="font-size: 13px; color: var(--color-text-secondary); margin-top: 8px;">@_inviteMessage</p>
    }
</div>

@if (_showAddAccount)
{
    <div class="modal-backdrop" @onclick="CloseAddAccount">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 16px;">계좌 추가</h2>
            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_newAccountName" placeholder="예: 생활비 통장" />
            </div>
            <div class="form-group">
                <label class="form-label">시작 잔액</label>
                <input class="form-input" type="number" @bind="_newAccountBalance" placeholder="0" />
            </div>
            <div class="form-group">
                <label class="form-label">계좌번호 (선택 · 암호화돼서 저장돼요)</label>
                <input class="form-input" @bind="_newAccountNumber" placeholder="입력 안 하면 저장 안 함" />
            </div>
            <div class="toggle-group" style="margin-bottom: 16px;">
                <button class="@(_newAccountShared ? "" : "active")" @onclick="() => _newAccountShared = false">나만 보기</button>
                <button class="@(_newAccountShared ? "active" : "")" @onclick="() => _newAccountShared = true">같이 보기</button>
            </div>
            @if (_error is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_error</p>
            }
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="CloseAddAccount">취소</button>
                <button class="btn btn-primary" style="flex: 2;" disabled="@_isSaving" @onclick="AddAccount">@(_isSaving ? "저장 중..." : "추가")</button>
            </div>
        </div>
    </div>
}

@if (_showEditAccount && _editingAccount is not null)
{
    <div class="modal-backdrop" @onclick="CloseEditAccount">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 16px;">계좌 수정</h2>
            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_editAccountName" placeholder="예: 생활비 통장" />
            </div>
            <div class="form-group">
                <label class="form-label">시작 잔액</label>
                <input class="form-input" type="number" @bind="_editAccountBalance" placeholder="0" />
            </div>
            <div class="toggle-group" style="margin-bottom: 16px;">
                <button class="@(_editAccountShared ? "" : "active")" @onclick="() => _editAccountShared = false">나만 보기</button>
                <button class="@(_editAccountShared ? "active" : "")" @onclick="() => _editAccountShared = true">같이 보기</button>
            </div>
            @if (_error is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_error</p>
            }
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="CloseEditAccount">취소</button>
                <button class="btn btn-primary" style="flex: 2;" disabled="@_isSaving" @onclick="SaveEditAccount">@(_isSaving ? "저장 중..." : "저장")</button>
            </div>
        </div>
    </div>
}

@if (_showEditCard && _editingCard is not null)
{
    <div class="modal-backdrop" @onclick="CloseEditCard">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 16px;">카드 수정</h2>
            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_editCardName" placeholder="예: 신한카드" />
            </div>
            <div class="form-group">
                <label class="form-label">청구 마감일 (일)</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_editCardStatementDay" />
            </div>
            <div class="form-group">
                <label class="form-label">결제일 (일)</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_editCardPaymentDay" />
            </div>
            @if (_error is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_error</p>
            }
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="CloseEditCard">취소</button>
                <button class="btn btn-primary" style="flex: 2;" disabled="@_isSaving" @onclick="SaveEditCard">@(_isSaving ? "저장 중..." : "저장")</button>
            </div>
        </div>
    </div>
}

@if (_showAddCard)
{
    <div class="modal-backdrop" @onclick="CloseAddCard">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 16px;">카드 추가</h2>
            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_newCardName" placeholder="예: 신한카드" />
            </div>
            <div class="form-group">
                <label class="form-label">청구 마감일 (일)</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_newCardStatementDay" />
            </div>
            <div class="form-group">
                <label class="form-label">결제일 (일)</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_newCardPaymentDay" />
            </div>
            <div class="form-group">
                <label class="form-label">카드번호 (선택 · 암호화돼서 저장돼요)</label>
                <input class="form-input" @bind="_newCardNumber" placeholder="입력 안 하면 저장 안 함" />
            </div>
            @if (_error is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_error</p>
            }
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="CloseAddCard">취소</button>
                <button class="btn btn-primary" style="flex: 2;" disabled="@_isSaving" @onclick="AddCard">@(_isSaving ? "저장 중..." : "추가")</button>
            </div>
        </div>
    </div>
}

@if (_showAddInstallment)
{
    <div class="modal-backdrop" @onclick="CloseAddInstallment">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 16px;">@(_editingInstallment is null ? "할부 추가" : "할부 수정")</h2>

            @if (_cards.Count == 0)
            {
                <p style="font-size: 13px; color: var(--color-text-secondary); margin-bottom: 16px;">먼저 카드를 등록해주세요.</p>
            }
            else
            {
                <div class="form-group">
                    <label class="form-label">카드</label>
                    <select class="form-select" @bind="_newInstallmentCardId">
                        @foreach (var c in _cards)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">구매처 / 메모</label>
                    <input class="form-input" @bind="_newInstallmentMerchant" placeholder="예: 노트북 구매" />
                </div>

                <div class="form-group">
                    <label class="form-label">카테고리 (선택)</label>
                    <select class="form-select" @bind="_newInstallmentCategoryId">
                        <option value="">선택 안 함</option>
                        @foreach (var cat in _categories.Where(c => c.Type == "expense"))
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">총 결제 금액</label>
                    <input class="form-input" type="number" @bind="_newInstallmentTotal" placeholder="0" />
                </div>

                <div class="form-group">
                    <label class="form-label">할부 개월수</label>
                    <input class="form-input" type="number" min="1" max="60" @bind="_newInstallmentMonths" />
                </div>

                @if (_editingInstallment is null)
                {
                    <div class="form-group">
                        <label class="form-label">첫 청구월 (그 달 1일에 첫 할부금이 기록돼요)</label>
                        <input class="form-input" type="month" value="@_newInstallmentStartMonth"
                               @onchange="e => _newInstallmentStartMonth = e.Value?.ToString() ?? _newInstallmentStartMonth" />
                    </div>
                }
                else
                {
                    <p style="font-size: 12px; color: var(--color-text-muted); margin-bottom: 12px;">
                        이미 @(_editingInstallment.MonthsGenerated)개월치가 기록됐어요. 총 금액/개월수를 바꾸면 앞으로 남은 회차부터 새 금액이 적용돼요.
                    </p>
                }

                @if (_newInstallmentTotal > 0 && _newInstallmentMonths > 0)
                {
                    <p style="font-size: 12px; color: var(--color-text-muted); margin-bottom: 12px;">
                        월 약 @((_newInstallmentTotal / _newInstallmentMonths).ToString("N0"))원씩 @(_newInstallmentMonths)개월
                    </p>
                }
            }

            @if (_error is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_error</p>
            }

            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="CloseAddInstallment">취소</button>
                <button class="btn btn-primary" style="flex: 2;" disabled="@_isSaving" @onclick="SaveInstallment">@(_isSaving ? "저장 중..." : (_editingInstallment is null ? "추가" : "저장"))</button>
            </div>
        </div>
    </div>
}

@if (_pinPromptMode is not null)
{
    <div class="modal-backdrop" @onclick="ClosePinPrompt">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 8px;">@(_pinPromptMode == PinMode.SetNew ? "잠금 PIN 만들기" : "PIN 입력")</h2>
            <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0 0 16px;">
                @(_pinPromptMode == PinMode.SetNew
                    ? "번호를 암호화할 PIN을 만들어주세요. 이 PIN은 저장되지 않고, 잊어버리면 번호를 복구할 수 없어요."
                    : "저장할 때 사용한 PIN을 입력해주세요.")
            </p>
            <div class="form-group">
                <input class="form-input" type="password" inputmode="numeric" @bind="_pinInput" placeholder="PIN" />
            </div>
            @if (_pinError is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_pinError</p>
            }
            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="ClosePinPrompt">취소</button>
                <button class="btn btn-primary" style="flex: 2;" @onclick="ConfirmPin">확인</button>
            </div>
        </div>
    </div>
}

@if (_copiedMessage is not null)
{
    <div style="position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%); background: var(--color-text); color: var(--color-bg); padding: 8px 16px; border-radius: 999px; font-size: 13px;">
        @_copiedMessage
    </div>
}

@code {
    List<Account> _accounts = new();
    List<Card> _cards = new();
    List<Transaction> _allTransactions = new();
    List<InstallmentPlan> _installments = new();
    List<Category> _categories = new();

    bool _showAddAccount;
    string _newAccountName = "";
    decimal _newAccountBalance;
    string _newAccountNumber = "";
    bool _newAccountShared;

    bool _showEditAccount;
    Account? _editingAccount;
    string _editAccountName = "";
    decimal _editAccountBalance;
    bool _editAccountShared;

    bool _showAddCard;
    string _newCardName = "";
    int _newCardStatementDay = 15;
    int _newCardPaymentDay = 25;
    string _newCardNumber = "";

    bool _showEditCard;
    Card? _editingCard;
    string _editCardName = "";
    int _editCardStatementDay = 15;
    int _editCardPaymentDay = 25;

    bool _showAddInstallment;
    InstallmentPlan? _editingInstallment;
    string _newInstallmentCardId = "";
    string _newInstallmentCategoryId = "";
    string _newInstallmentMerchant = "";
    decimal _newInstallmentTotal;
    int _newInstallmentMonths = 3;
    string _newInstallmentStartMonth = DateTime.Today.AddMonths(1).ToString("yyyy-MM");

    string _inviteEmail = "";
    string? _inviteMessage;
    string? _error;
    bool _isSaving;

    enum PinMode { SetNew, Reveal }
    PinMode? _pinPromptMode;
    string _pinInput = "";
    string? _pinError;
    Action<string>? _pinConfirmedCallback;

    EncryptedValue? _revealTarget;
    string? _copiedMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    async Task LoadAll()
    {
        var today = DateTime.Today;
        var rangeStart = today.AddMonths(-11).AddDays(1 - today.Day); // 12개월 전 달의 1일부터

        // 서로 관련 없는 조회들을 동시에 보내서 기다리는 시간을 줄입니다.
        var accountsTask = AccountRepo.GetAllAsync();
        var cardsTask = CardRepo.GetAllAsync();
        var installmentsTask = InstallmentRepo.GetAllAsync();
        var categoriesTask = CategoryRepo.GetAllAsync();
        var transactionsTask = TransactionRepo.GetByDateRangeAsync(rangeStart, today);

        await Task.WhenAll(accountsTask, cardsTask, installmentsTask, categoriesTask, transactionsTask);

        _accounts = accountsTask.Result;
        _cards = cardsTask.Result;
        _installments = installmentsTask.Result;
        _categories = categoriesTask.Result;
        _allTransactions = transactionsTask.Result;
    }

    void CloseAddAccount()
    {
        _showAddAccount = false;
        _newAccountName = "";
        _newAccountBalance = 0;
        _newAccountNumber = "";
        _error = null;
    }

    void CloseAddCard()
    {
        _showAddCard = false;
        _newCardName = "";
        _newCardNumber = "";
        _error = null;
    }

    void OpenEditAccount(Account a)
    {
        _editingAccount = a;
        _editAccountName = a.Name;
        _editAccountBalance = a.InitialBalance;
        _editAccountShared = a.IsShared;
        _error = null;
        _showEditAccount = true;
    }

    void CloseEditAccount()
    {
        _showEditAccount = false;
        _editingAccount = null;
        _error = null;
    }

    async Task SaveEditAccount()
    {
        if (_editingAccount is null || string.IsNullOrWhiteSpace(_editAccountName) || _isSaving) return;

        _isSaving = true;
        try
        {
            _editingAccount.Name = _editAccountName;
            _editingAccount.InitialBalance = _editAccountBalance;
            _editingAccount.IsShared = _editAccountShared;
            await AccountRepo.UpdateAsync(_editingAccount);
        }
        catch (Exception ex)
        {
            _error = $"저장 실패: {ex.Message}";
            return;
        }
        finally
        {
            _isSaving = false;
        }

        CloseEditAccount();
        await LoadAll();
    }

    async Task DeleteAccount(Guid id)
    {
        await AccountRepo.DeleteAsync(id);
        await LoadAll();
    }

    void OpenEditCard(Card c)
    {
        _editingCard = c;
        _editCardName = c.Name;
        _editCardStatementDay = c.StatementDay;
        _editCardPaymentDay = c.PaymentDay;
        _error = null;
        _showEditCard = true;
    }

    void CloseEditCard()
    {
        _showEditCard = false;
        _editingCard = null;
        _error = null;
    }

    async Task SaveEditCard()
    {
        if (_editingCard is null || string.IsNullOrWhiteSpace(_editCardName) || _isSaving) return;

        _isSaving = true;
        try
        {
            _editingCard.Name = _editCardName;
            _editingCard.StatementDay = _editCardStatementDay;
            _editingCard.PaymentDay = _editCardPaymentDay;
            await CardRepo.UpdateAsync(_editingCard);
        }
        catch (Exception ex)
        {
            _error = $"저장 실패: {ex.Message}";
            return;
        }
        finally
        {
            _isSaving = false;
        }

        CloseEditCard();
        await LoadAll();
    }

    async Task DeleteCard(Guid id)
