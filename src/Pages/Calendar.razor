@page "/"
@inject TransactionRepository TransactionRepo
@inject CardRepository CardRepo

<h1 style="font-size: 19px; margin: 0 0 16px;">원데이</h1>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-label">수입</div>
        <div class="summary-value text-income">+@MonthIncome.ToString("N0")</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">지출</div>
        <div class="summary-value text-expense">-@MonthExpense.ToString("N0")</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">순액</div>
        <div class="summary-value">@((MonthIncome - MonthExpense) >= 0 ? "+" : "")@((MonthIncome - MonthExpense).ToString("N0"))</div>
    </div>
</div>

<div class="card">
    <div class="calendar-header">
        <button @onclick="() => ChangeMonth(-1)"><i class="ti ti-chevron-left" aria-hidden="true"></i></button>
        <span class="calendar-title">@_currentMonth.ToString("yyyy년 M월")</span>
        <button @onclick="() => ChangeMonth(1)"><i class="ti ti-chevron-right" aria-hidden="true"></i></button>
    </div>

    <div class="calendar-weekdays">
        <span>일</span><span>월</span><span>화</span><span>수</span><span>목</span><span>금</span><span>토</span>
    </div>

    <div class="calendar-grid">
        @for (var i = 0; i < LeadingBlanks; i++)
        {
            <div></div>
        }
        @for (var day = 1; day <= DateTime.DaysInMonth(_currentMonth.Year, _currentMonth.Month); day++)
        {
            var d = day;
            var total = DayTotal(d);
            <button class="calendar-cell @(IsSelected(d) ? "selected" : "")" @onclick="() => SelectDate(d)">
                <span class="day-number">@d</span>
                @if (total != 0)
                {
                    <span class="day-amount @(total > 0 ? "text-income" : "text-expense")">
                        @(total > 0 ? "+" : "-")@(Math.Abs(total).ToString("N0"))
                    </span>
                }
            </button>
        }
    </div>
</div>

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
        <span style="font-size: 14px; font-weight: 600;">@_selectedDate.ToString("M월 d일")</span>
        <span style="font-size: 13px; color: var(--color-text-muted);">@DayTotal(_selectedDate.Day).ToString("N0")원</span>
    </div>

    @if (SelectedDateTransactions.Count == 0)
    {
        <div class="empty-state">이 날은 기록된 내역이 없어요.</div>
    }
    else
    {
        @foreach (var t in SelectedDateTransactions)
        {
            <div class="transaction-row" style="cursor: pointer;" @onclick="() => OpenEditForm(t)">
                <div class="transaction-icon"><i class="ti ti-receipt" aria-hidden="true"></i></div>
                <div class="transaction-info">
                    <div class="transaction-title">@(string.IsNullOrEmpty(t.Memo) ? "메모 없음" : t.Memo)</div>
                    <div class="transaction-sub">
                        @(t.IsShared ? "같이 보기" : "나만 보기")
                        @if (t.PaymentCardId is not null)
                        {
                            <text> · @t.Date.ToString("M월 d일")에 결제</text>
                        }
                    </div>
                </div>
                <div class="@(t.Type == "income" ? "text-income" : "text-expense")" style="font-weight: 600; font-size: 14px;">
                    @(t.Type == "income" ? "+" : "-")@t.Amount.ToString("N0")원
                </div>
            </div>
        }
    }
</div>

<button class="btn-fab" @onclick="OpenForm" aria-label="내역 추가">
    <i class="ti ti-plus" aria-hidden="true"></i>
</button>

@if (_showForm)
{
    <TransactionFormModal InitialDate="_selectedDate" EditingTransaction="_editingTransaction"
                           OnSaved="HandleSaved" OnCancelled="CloseForm" OnDeleted="HandleDeleted" />
}

@code {
    DateTime _currentMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    DateTime _selectedDate = DateTime.Today;
    List<Transaction> _monthTransactions = new();
    Dictionary<Guid, Card> _cardsById = new();
    bool _showForm;
    Transaction? _editingTransaction;

    int LeadingBlanks => (int)_currentMonth.DayOfWeek;

    decimal MonthIncome => _monthTransactions.Where(t => t.Type == "income").Sum(t => t.Amount);
    decimal MonthExpense => _monthTransactions.Where(t => t.Type == "expense").Sum(t => t.Amount);

    // 카드 결제는 실제 구매일이 아니라 카드의 결제일(다음달)을 기준으로 이 화면에 표시돼요.
    DateTime DisplayDate(Transaction t) => CardRepo.GetDisplayDate(t, _cardsById);

    List<Transaction> SelectedDateTransactions =>
        _monthTransactions.Where(t => DisplayDate(t).Date == _selectedDate.Date).ToList();

    protected override async Task OnInitializedAsync()
    {
        var cards = await CardRepo.GetAllAsync();
        _cardsById = cards.ToDictionary(c => c.Id, c => c);
        await LoadMonth();
    }

    async Task LoadMonth()
    {
        // 카드 거래가 다음달로 표시될 수 있으므로, 저번 달 거래까지 넉넉히 불러온 뒤
        // 표시 기준 날짜(DisplayDate)가 이번 달에 해당하는 것만 걸러냅니다.
        var rangeStart = _currentMonth.AddMonths(-1);
        var rangeEnd = _currentMonth.AddMonths(1).AddDays(-1);
        var candidates = await TransactionRepo.GetByDateRangeAsync(rangeStart, rangeEnd);

        _monthTransactions = candidates
            .Where(t => DisplayDate(t).Year == _currentMonth.Year && DisplayDate(t).Month == _currentMonth.Month)
            .ToList();
    }

    decimal DayTotal(int day)
    {
        return _monthTransactions
            .Where(t => DisplayDate(t).Day == day && DisplayDate(t).Month == _currentMonth.Month && t.Type != "transfer")
            .Sum(t => t.Type == "income" ? t.Amount : -t.Amount);
    }

    bool IsSelected(int day) =>
        _selectedDate.Year == _currentMonth.Year && _selectedDate.Month == _currentMonth.Month && _selectedDate.Day == day;

    async Task ChangeMonth(int delta)
    {
        _currentMonth = _currentMonth.AddMonths(delta);
        _selectedDate = _currentMonth;
        await LoadMonth();
    }

    void SelectDate(int day)
    {
        _selectedDate = new DateTime(_currentMonth.Year, _currentMonth.Month, day);
    }

    void OpenForm()
    {
        _editingTransaction = null;
        _showForm = true;
    }

    void OpenEditForm(Transaction t)
    {
        _editingTransaction = t;
        _showForm = true;
    }

    void CloseForm()
    {
        _showForm = false;
        _editingTransaction = null;
    }

    async Task HandleSaved()
    {
        CloseForm();
        await LoadMonth();
    }

    async Task HandleDeleted()
    {
        CloseForm();
        await LoadMonth();
    }
}
