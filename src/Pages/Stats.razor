@page "/stats"
@inject TransactionRepository TransactionRepo
@inject BudgetService BudgetSvc
@inject CategoryRepository CategoryRepo
@inject CardRepository CardRepo

<h1 style="font-size: 19px; margin: 0 0 16px;">통계</h1>

<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-label">이번 달 지출</div>
        <div class="summary-value">@_monthExpense.ToString("N0")</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">일 평균</div>
        <div class="summary-value">@_dailyAverage.ToString("N0")</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">거래 건수</div>
        <div class="summary-value">@_transactionCount</div>
    </div>
</div>

<h2 style="font-size: 15px; margin: 20px 0 10px;">오늘 쓸 수 있는 만큼만</h2>

@if (_budgetStatuses.Count == 0)
{
    <div class="empty-state">예산이 설정된 카테고리가 없어요.<br /><a href="/budgets">예산 설정에서 등록해보세요</a></div>
}
else
{
    @foreach (var status in _budgetStatuses)
    {
        <CategoryBudgetCard Status="status" />
    }
}

<h2 style="font-size: 15px; margin: 20px 0 10px;">카테고리별 지출</h2>

<div class="card">
    @if (_categoryTotals.Count == 0)
    {
        <div class="empty-state">이번 달 지출 내역이 없어요.</div>
    }
    else
    {
        @foreach (var item in _categoryTotals)
        {
            var maxAmount = _categoryTotals.Max(c => c.Amount);
            var pct = maxAmount > 0 ? (double)(item.Amount / maxAmount) * 100 : 0;
            <div style="margin-bottom: 10px;">
                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px; margin-bottom: 4px;">
                    <span style="display: flex; align-items: center; gap: 6px;">
                        <span style="width: 22px; height: 22px; border-radius: 50%; background: @(item.Color)33; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="ti @item.Icon" style="font-size: 12px; color: @item.Color;" aria-hidden="true"></i>
                        </span>
                        @item.Name
                    </span>
                    <span style="color: var(--color-text-secondary);">@item.Amount.ToString("N0")원</span>
                </div>
                <div class="budget-gauge-track">
                    <div class="budget-gauge-fill" style="width: @(pct.ToString("0"))%; background: @item.Color;"></div>
                </div>
            </div>
        }
    }
</div>

@code {
    List<CategoryBudgetStatus> _budgetStatuses = new();
    List<CategoryTotal> _categoryTotals = new();
    decimal _monthExpense;
    decimal _dailyAverage;
    int _transactionCount;

    static readonly string FallbackColor = "#b3a4d9";
    static readonly string FallbackIcon = "ti-tag";

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        _budgetStatuses = await BudgetSvc.GetTodayStatusAsync(today);

        var cards = await CardRepo.GetAllAsync();
        var cardsById = cards.ToDictionary(c => c.Id, c => c);

        // 카드 지출은 다음달 결제일 기준으로 잡히므로, 저번 달 거래까지 같이 불러와서
        // 표시 기준 날짜(DisplayDate)가 이번 달인 것만 걸러냅니다.
        var monthStart = new DateTime(today.Year, today.Month, 1);
        var rangeStart = monthStart.AddMonths(-1);
        var rangeEnd = monthStart.AddMonths(1).AddDays(-1);
        var candidates = await TransactionRepo.GetByDateRangeAsync(rangeStart, rangeEnd);

        var monthTransactions = candidates
            .Where(t =>
            {
                var d = CardRepo.GetDisplayDate(t, cardsById);
                return d.Year == today.Year && d.Month == today.Month;
            })
            .ToList();

        var expenses = monthTransactions.Where(t => t.Type == "expense").ToList();

        _monthExpense = expenses.Sum(t => t.Amount);
        _transactionCount = expenses.Count;
        _dailyAverage = today.Day > 0 ? _monthExpense / today.Day : 0;

        var categories = await CategoryRepo.GetAllAsync();
        var categoryLookup = categories.ToDictionary(c => c.Id, c => c);

        _categoryTotals = expenses
            .Where(t => t.CategoryId.HasValue)
            .GroupBy(t => t.CategoryId!.Value)
            .Select(g =>
            {
                var cat = categoryLookup.GetValueOrDefault(g.Key);
                return new CategoryTotal
                {
                    Name = cat?.Name ?? "미분류",
                    Amount = g.Sum(t => t.Amount),
                    Color = cat?.Color ?? FallbackColor,
                    Icon = cat?.Icon ?? FallbackIcon
                };
            })
            .OrderByDescending(c => c.Amount)
            .ToList();
    }

    class CategoryTotal
    {
        public string Name { get; set; } = "";
        public decimal Amount { get; set; }
        public string Color { get; set; } = "";
        public string Icon { get; set; } = "";
    }
}
