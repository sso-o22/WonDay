@page "/recurring"
@inject RecurringExpenseRepository RecurringRepo
@inject CategoryRepository CategoryRepo
@inject AccountRepository AccountRepo
@inject CardRepository CardRepo

<h1 style="font-size: 19px; margin: 0 0 16px;">정기결제 · 고정지출</h1>

<p style="font-size: 12px; color: var(--color-text-muted); margin: 0 0 16px;">
    구독료, 적금 이체처럼 매달 같은 날 나가는 지출을 등록해두면, 앱을 열 때마다 그동안 지난 달 만큼 자동으로 기록돼요.
</p>

@if (_items.Count == 0)
{
    <div class="empty-state">등록된 정기결제가 없어요.</div>
}
else
{
    @foreach (var item in _items)
    {
        var methodName = item.PaymentAccountId is not null
            ? _accounts.FirstOrDefault(a => a.Id == item.PaymentAccountId)?.Name
            : _cards.FirstOrDefault(c => c.Id == item.PaymentCardId)?.Name;

        <div class="card" style="display: flex; align-items: center; justify-content: space-between; @(item.IsActive ? "" : "opacity: 0.5;")">
            <div>
                <div style="font-size: 14px; font-weight: 600;">@item.Name</div>
                <div style="font-size: 12px; color: var(--color-text-muted);">매달 @(item.DayOfMonth)일 · @methodName · @(item.IsActive ? "진행중" : "중지됨")</div>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 14px; font-weight: 600;">@item.Amount.ToString("N0")원</span>
                <button class="btn" style="padding: 5px 10px; font-size: 12px;" @onclick="() => ToggleActive(item)">@(item.IsActive ? "중지" : "재개")</button>
                <button class="btn" style="padding: 5px 10px; font-size: 12px;" @onclick="() => DeleteItem(item.Id)">삭제</button>
            </div>
        </div>
    }
}

<button class="btn btn-primary btn-full" style="margin-top: 16px;" @onclick="OpenAdd">+ 정기결제 추가</button>

@if (_showAdd)
{
    <div class="modal-backdrop" @onclick="() => _showAdd = false">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <h2 style="font-size: 17px; margin: 0 0 16px;">정기결제 추가</h2>

            <div class="form-group">
                <label class="form-label">이름</label>
                <input class="form-input" @bind="_newName" placeholder="예: 넷플릭스, 적금 이체" />
            </div>

            <div class="form-group">
                <label class="form-label">금액</label>
                <input class="form-input" type="number" @bind="_newAmount" placeholder="0" />
            </div>

            <div class="form-group">
                <label class="form-label">카테고리 (선택)</label>
                <select class="form-select" @bind="_newCategoryId">
                    <option value="">선택 안 함</option>
                    @foreach (var cat in _categories.Where(c => c.Type == "expense"))
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">결제 수단</label>
                <select class="form-select" @bind="_newPaymentMethod">
                    <option value="">선택</option>
                    <optgroup label="계좌/현금">
                        @foreach (var a in _accounts)
                        {
                            <option value="account:@a.Id">@a.Name</option>
                        }
                    </optgroup>
                    <optgroup label="카드">
                        @foreach (var c in _cards)
                        {
                            <option value="card:@c.Id">@c.Name</option>
                        }
                    </optgroup>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">매달 나가는 날</label>
                <input class="form-input" type="number" min="1" max="31" @bind="_newDayOfMonth" />
            </div>

            <div class="form-group">
                <label class="form-label">시작월</label>
                <input class="form-input" type="month" value="@_newStartMonth"
                       @onchange="e => _newStartMonth = e.Value?.ToString() ?? _newStartMonth" />
            </div>

            @if (_error is not null)
            {
                <p class="text-danger" style="font-size: 13px; margin-bottom: 12px;">@_error</p>
            }

            <div style="display: flex; gap: 8px;">
                <button class="btn" style="flex: 1;" @onclick="() => _showAdd = false">취소</button>
                <button class="btn btn-primary" style="flex: 2;" disabled="@_isSaving" @onclick="AddItem">@(_isSaving ? "저장 중..." : "추가")</button>
            </div>
        </div>
    </div>
}

@code {
    List<RecurringExpense> _items = new();
    List<Category> _categories = new();
    List<Account> _accounts = new();
    List<Card> _cards = new();

    bool _showAdd;
    string _newName = "";
    decimal _newAmount;
    string _newCategoryId = "";
    string _newPaymentMethod = "";
    int _newDayOfMonth = 1;
    string _newStartMonth = DateTime.Today.ToString("yyyy-MM");
    string? _error;
    bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    async Task Load()
    {
        _items = await RecurringRepo.GetAllAsync();
        _categories = await CategoryRepo.GetAllAsync();
        _accounts = await AccountRepo.GetAllAsync();
        _cards = await CardRepo.GetAllAsync();
    }

    void OpenAdd()
    {
        _newName = "";
        _newAmount = 0;
        _newCategoryId = "";
        _newPaymentMethod = "";
        _newDayOfMonth = 1;
        _newStartMonth = DateTime.Today.ToString("yyyy-MM");
        _error = null;
        _showAdd = true;
    }

    async Task AddItem()
    {
        if (_isSaving) return;

        if (string.IsNullOrWhiteSpace(_newName) || _newAmount <= 0 || string.IsNullOrEmpty(_newPaymentMethod))
        {
            _error = "필수 항목을 모두 입력해주세요.";
            return;
        }

        _isSaving = true;
        try
        {
            var parts = _newPaymentMethod.Split(':');
            Guid? accountId = parts[0] == "account" ? Guid.Parse(parts[1]) : null;
            Guid? cardId = parts[0] == "card" ? Guid.Parse(parts[1]) : null;
            Guid? categoryId = string.IsNullOrEmpty(_newCategoryId) ? null : Guid.Parse(_newCategoryId);
            var startMonth = DateTime.ParseExact(_newStartMonth + "-01", "yyyy-MM-dd", null);

            await RecurringRepo.CreateAsync(_newName, _newAmount, categoryId, accountId, cardId, _newDayOfMonth, startMonth, isShared: false);
            await RecurringRepo.GenerateDueTransactionsAsync();
        }
        catch (Exception ex)
        {
            _error = $"저장 실패: {ex.Message}";
            return;
        }
        finally
        {
            _isSaving = false;
        }

        _showAdd = false;
        await Load();
    }

    async Task ToggleActive(RecurringExpense item)
    {
        await RecurringRepo.SetActiveAsync(item, !item.IsActive);
        await Load();
    }

    async Task DeleteItem(Guid id)
    {
        await RecurringRepo.DeleteAsync(id);
        await Load();
    }
}
